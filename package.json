{
  "name": "homelabinator",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "node build.mjs",
    "test:website": "http-server . -c-1 -o tests/integration/test_website/",
    "test:vm": "nix-build '<nixpkgs/nixos>' -A vm -I nixpkgs=channel:nixos-25.11 -I nixos-config=./tests/integration/playground/config.nix && QEMU_KERNEL_PARAMS=console=ttyS0 ./result/bin/run-nixos-vm -nographic -m 8192 -smp 2; reset",
    "test:vm:reset": "rm -f result nixos*",
    "app": "vite",
    "prod": "ENV_NAME=prod vite",
    "convert": "node convert_md_to_json.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "dexie": "^4.3.0",
    "esbuild": "^0.23.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.14.9",
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "front-matter": "^4.0.2",
    "glob": "^13.0.6",
    "http-server": "^14.1.1",
    "js-yaml": "^4.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.5.2",
    "vite": "^7.3.1"
  }
}
