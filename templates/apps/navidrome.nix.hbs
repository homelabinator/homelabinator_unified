services.k3s.manifests.{{app.name}}.content = [
  {
    apiVersion = "apps/v1";
    kind = "Deployment";
    metadata = {
      name = "{{app.name}}";
      labels.app = "{{app.name}}";
    };
    spec = {
      replicas = 1;
      selector.matchLabels.app = "{{app.name}}";
      template = {
        metadata.labels.app = "{{app.name}}";
        spec = {
          containers = [
            {
              name = "{{app.name}}";
              image = "deluan/navidrome:latest";
              env = [
                { name = "ND_MUSICFOLDER"; value = "/music"; }
                { name = "ND_DATAFOLDER"; value = "/data"; }
                { name = "TZ"; value = "Etc/UTC"; }
              ];
              ports = [
                {{hook_port 4533 "http"}}
              ];
              volumeMounts = [
                {{hook_volume "data" "/data"}}
                {{hook_volume "music" "/music"}}
              ];
            }
          ];
          volumes = [
            {{hook_volumes_pod}}
          ];
          tolerations = [
            {
              key = "node-role.kubernetes.io/master";
              operator = "Exists";
              effect = "NoSchedule";
            }
            {
              key = "node-role.kubernetes.io/control-plane";
              operator = "Exists";
              effect = "NoSchedule";
            }
          ];
        };
      };
    };
  }
];
