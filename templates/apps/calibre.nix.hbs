services.k3s.manifests.calibre.content = [
      {
        apiVersion = "apps/v1";
        kind = "Deployment";
        metadata = {
          name = "calibre";
          labels.app = "calibre";
        };
        spec = {
          replicas = 1;
          selector.matchLabels.app = "calibre";
          template = {
            metadata.labels.app = "calibre";
            spec = {
              containers = [
                {
                  name = "calibre";
                  image = "lscr.io/linuxserver/calibre:latest";
                  securityContext = {
                    seccompProfile.type = "Unconfined";
                  };
                  env = [
                    { name = "PUID"; value = "1000"; }
                    { name = "PGID"; value = "1000"; }
                    { name = "TZ"; value = "Etc/UTC"; }
                  ];
                  ports = [
                    { containerPort = 8080; name = "web"; }
                    { containerPort = 8181; name = "wireless"; }
                    { containerPort = 8081; name = "content"; }
                  ];
                  volumeMounts = [
                    { name = "config"; mountPath = "/config"; }
                    { name = "dshm"; mountPath = "/dev/shm"; }
                  ];
                }
              ];
              volumes = [
                {
                  name = "config";
                  hostPath = {
                    path = "/home/homelab/{{app.name}}/config";
                    type = "DirectoryOrCreate";
                  };
                }
                {
                  name = "dshm";
                  emptyDir = {
                    medium = "Memory";
                    sizeLimit = "1Gi";
                  };
                }
              ];
              tolerations = [
                {
                  key = "node-role.kubernetes.io/master";
                  operator = "Exists";
                  effect = "NoSchedule";
                }
                {
                  key = "node-role.kubernetes.io/control-plane";
                  operator = "Exists";
                  effect = "NoSchedule";
                }
              ];
            };
          };
        };
      }
      {
        apiVersion = "v1";
        kind = "Service";
        metadata = {
          name = "calibre-svc";
          labels.app = "calibre";
        };
        spec = {
          type = "ClusterIP";
          selector.app = "calibre";
          ports = [
            { port = 8080; targetPort = 8080; name = "web"; }
            { port = 8181; targetPort = 8181; name = "wireless"; }
            { port = 8081; targetPort = 8081; name = "content"; }
          ];
        };
      }
      {{{services}}}
    ];