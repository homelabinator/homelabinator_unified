services.k3s.manifests.{{app.name}}.content = [
  {
    apiVersion = "apps/v1";
    kind = "Deployment";
    metadata = {
      name = "{{app.name}}";
      labels.app = "{{app.name}}";
    };
    spec = {
      replicas = 1;
      selector.matchLabels.app = "{{app.name}}";
      template = {
        metadata.labels.app = "{{app.name}}";
        spec = {
          containers = [
            {
              name = "{{app.name}}";
              image = "lscr.io/linuxserver/calibre:latest";
              securityContext = {
                seccompProfile.type = "Unconfined";
              };
              env = [
                { name = "PUID"; value = "1000"; }
                { name = "PGID"; value = "1000"; }
                { name = "TZ"; value = "Etc/UTC"; }
              ];
              ports = [
                {{hook_port 8080 "web"}}
                {{hook_port 8181 "wireless"}}
                {{hook_port 8081 "content"}}
              ];
              volumeMounts = [
                {{hook_volume "config" "/config"}}
                {{hook_volume "dshm" "/dev/shm"}}
              ];
            }
          ];
          volumes = [
            {{hook_volumes_pod}}
          ];
          tolerations = [
            {
              key = "node-role.kubernetes.io/master";
              operator = "Exists";
              effect = "NoSchedule";
            }
            {
              key = "node-role.kubernetes.io/control-plane";
              operator = "Exists";
              effect = "NoSchedule";
            }
          ];
        };
      };
    };
  }
];
