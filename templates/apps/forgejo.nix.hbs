services.k3s.manifests.{{app.name}}.content = [
  {
    apiVersion = "apps/v1";
    kind = "Deployment";
    metadata = {
      name = "{{app.name}}";
      labels.app = "{{app.name}}";
    };
    spec = {
      replicas = 1;
      selector.matchLabels.app = "{{app.name}}";
      template = {
        metadata.labels.app = "{{app.name}}";
        spec = {
          containers = [
            {
              name = "{{app.name}}";
              image = "codeberg.org/forgejo/forgejo:latest";
              env = [
                { name = "USER_UID"; value = "1000"; }
                { name = "USER_GID"; value = "1000"; }
              ];
              ports = [
                {{hook_port 3000 "http"}}
                {{hook_port 22 "ssh"}}
              ];
              volumeMounts = [
                {{hook_volume "data" "/data"}}
              ];
            }
          ];
          volumes = [
            {{hook_volumes_pod}}
          ];
          tolerations = [
            {
              key = "node-role.kubernetes.io/master";
              operator = "Exists";
              effect = "NoSchedule";
            }
            {
              key = "node-role.kubernetes.io/control-plane";
              operator = "Exists";
              effect = "NoSchedule";
            }
          ];
        };
      };
    };
  }
];
