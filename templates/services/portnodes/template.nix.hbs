{
  apiVersion = "v1";
  kind = "Service";
  metadata = {
    name = "{{{app.name}}}-portnodes-svc";
  };
  spec = {
    type = "NodePort";
    selector.app = "{{{app.name}}}";
    ports = [
      {
        port = {{{app.port}}};
        targetPort = {{{app.port}}};
        name = "portnodes";
      }
    ];
  };
}
{
  apiVersion = "networking.k8s.io/v1";
  kind = "Ingress";
  metadata.name = "{{{app.name}}}-portnodes-ingress";
  spec = {
    ingressClassName = "portnodes";
    rules = [
      {
        http = {
          paths = [
            {
              path = "/";
              pathType = "Prefix";
              backend.service = {
                name = "{{{app.name}}}-svc";
                port.number = {{{app.port}}};
              };
            }
          ];
        };
      }
    ];
  };
}
