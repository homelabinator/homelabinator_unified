{
        apiVersion = "networking.k8s.io/v1";
        kind = "Ingress";
        metadata.name = "{{{app.name}}}-ingress";
        spec = {
          ingressClassName = "tailscale";
          rules = [
            {
              http = {
                paths = [
                  {
                    path = "/";
                    pathType = "Prefix";
                    backend.service = {
                      name = "{{{app.name}}}-svc";
                      port.number = {{{app.port}}};
                    };
                  }
                ];
              };
            }
          ];
        };
      }