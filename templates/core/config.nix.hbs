{ config, pkgs, ... }:
{
    # Auto login
    services.getty.autologinUser = "homelab";
    security.sudo.wheelNeedsPassword = false;

    # Homelabinator Setup
    services.filebrowser.enable = true;
    services.k3s.enable = true;
    services.k3s.role = "server";
    services.k3s.extraFlags = toString [
      "--disable traefik"
    ];

    {{{apps}}}
    {{{volumes}}}
    {{{services}}}

    {{{globalservices}}}
}
