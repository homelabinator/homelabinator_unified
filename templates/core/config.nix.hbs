    # Auto login
    services.getty.autologinUser = "homelab";
    security.sudo.wheelNeedsPassword = false;
    networking.firewall.enable = false;

    # *** BEGIN HOMELABINATOR FIRST TIME SETUP
    environment.etc."homelabinator-config".text = ''
      services.filebrowser.enable = true;
      services.k3s.enable = true;
      services.k3s.role = "server";
      services.k3s.extraFlags = toString [
        "--disable traefik"
      ];

      {{{apps}}}
      {{{volumes}}}
      {{{services}}}

      {{{globalservices}}}
    '';
    # *** END HOMELABINATOR FIRST TIME SETUP
